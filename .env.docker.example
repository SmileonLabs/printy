OPENAI_API_KEY=

POSTGRES_DB=printy
POSTGRES_USER=printy
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_PORT=5432
DATABASE_URL=postgresql://printy:change-me-in-production@postgres:5432/printy
SESSION_SECRET=
# Local Docker uses http://localhost. Set this to 0 behind HTTPS in production.
PRINTY_ALLOW_INSECURE_COOKIES=1

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
KAKAO_REDIRECT_URI=http://localhost:3000/api/auth/kakao/callback

PRINTY_ADMIN_CONTACTS=
PRINTY_ADMIN_TOKEN=

PRINTY_GHOSTSCRIPT_PATH=/usr/bin/gs
PRINTY_QPDF_PATH=/usr/bin/qpdf
PRINTY_CHROMIUM_PATH=/usr/bin/chromium
# Default image profile: zlib-licensed basICColor ISOcoated_v2_bas.ICC.
# To override with a print-shop-specific mounted profile, place it under ./ops/color
# and set PRINTY_CMYK_ICC_PATH=/opt/printy/color-overrides/<profile>.icc.
PRINTY_CMYK_ICC_PATH=/opt/printy/color/ISOcoated_v2_bas.ICC

# veraPDF CLI is available at /opt/verapdf/verapdf for PDF/A/PDF/UA/WTPDF checks.
# Do not use plain veraPDF as PDF/X certification unless wrapped with a real PDF/X-capable policy/check.
# Simple quoted args are supported; use a wrapper script for shell logic or complex policies.
PRINTY_PREFLIGHT_COMMAND=
PRINTY_PREFLIGHT_ARGS=--format text {pdf}

# Optional fail-closed wrapper smoke. This must report validation-failed until replaced
# with a real PDF/X-capable validator wrapper that exits 0 only after true PDF/X validation.
# PRINTY_PREFLIGHT_COMMAND=/bin/sh
# PRINTY_PREFLIGHT_ARGS="/opt/printy/preflight/example-pdfx-validator.sh {pdf}"
