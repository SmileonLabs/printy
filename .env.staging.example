# Staging uses a separate Supabase project/database from production.
# Do not point local development at the production DATABASE_URL.
DATABASE_URL=postgresql://postgres:<password>@<staging-host>:5432/postgres?sslmode=require
PGSSLMODE=require
SESSION_SECRET=

OPENAI_API_KEY=
OPENAI_IMAGE_MODEL=gpt-image-2
OPENAI_REFERENCE_ANALYSIS_MODEL=gpt-4.1-mini

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://staging.example.com/api/auth/google/callback

KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
KAKAO_REDIRECT_URI=https://staging.example.com/api/auth/kakao/callback

PRINTY_ADMIN_CONTACTS=
PRINTY_ADMIN_TOKEN=
PRINTY_ALLOW_INSECURE_COOKIES=false

# Native prepress paths are provided by the Docker/container runtime.
PRINTY_GHOSTSCRIPT_PATH=/usr/bin/gs
PRINTY_QPDF_PATH=/usr/bin/qpdf
PRINTY_CHROMIUM_PATH=/usr/bin/chromium
PRINTY_CMYK_ICC_PATH=/opt/printy/color/ISOcoated_v2_bas.ICC
PRINTY_PREFLIGHT_COMMAND=
PRINTY_PREFLIGHT_ARGS=
